# OpenAI (for LLM-based extraction, suggestions, etc.)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Weaviate (vector store - docker-compose up)
WEAVIATE_URL=http://localhost:8080

# Neo4j (optional - pipeline works without it for vector-only)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# spaCy model: fr_core_news_sm (French) or en_core_web_sm (English)
SPACY_MODEL=fr_core_news_sm
